# Hume (get free key at https://app.hume.ai/keys)
HUME_API_KEY=your_hume_api_key_here

# ElevenLabs (get free key at https://elevenlabs.io)
ELEVENLABS_API_KEY=your_api_key_here

# Twilio credentials
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Server
HOST=0.0.0.0
PORT=8765

# Whisper
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large-v3
# base is a good balance of speed/quality for real-time

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Piper TTS
PIPER_VOICE=en_US-lessac-medium
# Voice files are stored in ./voices/

# Recording (set to true to save call audio)
RECORD_CALLS=false
RECORDINGS_DIR=./recordings
